{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/pixel-travel-map/trip.schema.json",
  "title": "PixelTravelMap Itinerary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trip_title",
    "start_date",
    "end_date",
    "travelers",
    "transport",
    "style_theme",
    "lang",
    "days"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "trip_title": {
      "type": "string",
      "minLength": 1
    },
    "start_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "end_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "travelers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "budget_cny": {
      "type": ["integer", "number", "null"],
      "minimum": 0
    },
    "transport": {
      "type": "string",
      "enum": ["self-drive", "train", "public-transit", "walk", "mixed", "unknown"]
    },
    "style_theme": {
      "type": "string",
      "enum": ["pastel-pixel", "cyberpunk-neon", "vintage-parchment", "monochrome-ink", "forest-ghibli"]
    },
    "lang": {
      "type": "string",
      "enum": ["zh-CN", "en-US"]
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/day"
      }
    }
  },
  "$defs": {
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": ["day", "date", "stops"],
      "properties": {
        "day": {
          "type": "integer",
          "minimum": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "summary": {
          "type": "string"
        },
        "stops": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stop"
          }
        }
      }
    },
    "stop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "city",
        "country",
        "lat",
        "lon",
        "crs",
        "category",
        "duration_min",
        "notes",
        "source",
        "info_missing"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "name_en": {
          "type": ["string", "null"]
        },
        "city": {
          "type": "string",
          "minLength": 1
        },
        "country": {
          "type": "string",
          "minLength": 2
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "crs": {
          "type": "string",
          "enum": ["wgs84", "gcj02"]
        },
        "category": {
          "type": "string",
          "enum": ["landmark", "museum", "food", "hotel", "nature", "transit", "shopping", "experience", "viewpoint"]
        },
        "duration_min": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        },
        "description": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": ["string", "null"]
        },
        "official_url": {
          "type": ["string", "null"]
        },
        "navigation_url": {
          "type": ["string", "null"]
        },
        "info_missing": {
          "type": "boolean"
        }
      }
    }
  }
}
